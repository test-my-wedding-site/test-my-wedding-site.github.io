{
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,

  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "wedding-content\\.json$",
        "cmd": "json-minify \"${file}\" > \"${fileDirname}\\wedding-content.min.json\""
      },
      {
        "match": "html_content_loader\\.js$",
        "cmd": "terser \"${file}\" -o \"${fileDirname}\\html_content_loader.min.js\" -c -m"
      },
      {
        "match": "script_loader\\.js$",
        "cmd": "terser \"${file}\" -o \"${fileDirname}\\script_loader.min.js\" -c -m"
      },
      {
        "match": "animation\\.js$",
        "cmd": "terser \"${file}\" -o \"${fileDirname}\\animation.min.js\" -c -m"
      },
      {
        "match": "content\\.js$",
        "cmd": "terser \"${file}\" -o \"${fileDirname}\\content.min.js\" -c -m"
      },
      {
        "match": "script\\.js$",
        "cmd": "terser \"${file}\" -o \"${fileDirname}\\script.min.js\" -c -m"
      },
      {
        "match": "listener\\.js$",
        "cmd": "terser \"${file}\" -o \"${fileDirname}\\listener.min.js\" -c -m"
      },
      {
        "match": "style\\.css$",
        "cmd": "cleancss -o \"${fileDirname}\\style.min.css\" \"${file}\""
      },
      {
        "match": "fonts\\.css$",
        "cmd": "cleancss -o \"${fileDirname}\\fonts.min.css\" \"${file}\""
      }
    ]
  }
}